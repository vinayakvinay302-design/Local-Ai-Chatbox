import pytest

from chatbot.engine import ChatEngine, FALLBACK_TAG


@pytest.fixture()
def engine() -> ChatEngine:
    return ChatEngine(seed=42)


def test_greeting_matches_greeting_intent(engine: ChatEngine):
    match = engine.classify("hello there")
    assert match.intent.tag == "greeting"


def test_unknown_input_falls_back(engine: ChatEngine):
    match = engine.classify("xyzzy quantum banana flux")
    assert match.intent.tag == FALLBACK_TAG


def test_get_response_returns_nonempty_string(engine: ChatEngine):
    reply = engine.get_response("hi")
    assert isinstance(reply, str)
    assert len(reply) > 0


def test_empty_input_handled_gracefully(engine: ChatEngine):
    reply = engine.get_response("   ")
    assert "type something" in reply.lower()


def test_history_records_conversation(engine: ChatEngine):
    engine.get_response("hi")
    engine.get_response("thanks")
    assert len(engine.history) == 2
    assert engine.history[0][0] == "hi"


def test_missing_intents_file_raises(tmp_path):
    missing = tmp_path / "does_not_exist.json"
    with pytest.raises(FileNotFoundError):
        ChatEngine(intents_path=missing)
