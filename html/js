"""Core matching engine for the rule-based chatbot.

The engine loads a JSON file of intents (tag, patterns, responses) and
matches user input against those patterns using normalized token overlap
combined with sequence similarity. Everything runs locally using only the
Python standard library -- no network calls, no API keys.
"""

from __future__ import annotations

import json
import random
import re
import string
from dataclasses import dataclass
from difflib import SequenceMatcher
from pathlib import Path
from typing import List, Optional


DEFAULT_INTENTS_PATH = Path(__file__).parent / "intents.json"
FALLBACK_TAG = "fallback"
MATCH_THRESHOLD = 0.45


@dataclass(frozen=True)
class Intent:
    """A single conversational intent."""

    tag: str
    patterns: List[str]
    responses: List[str]


@dataclass(frozen=True)
class Match:
    """Result of matching user input against known intents."""

    intent: Intent
    score: float
    matched_pattern: Optional[str]


def _normalize(text: str) -> str:
    """Lowercase, strip punctuation, and collapse whitespace."""
    text = text.lower().strip()
    text = text.translate(str.maketrans("", "", string.punctuation))
    text = re.sub(r"\s+", " ", text)
    return text


def _similarity(a: str, b: str) -> float:
    """Blend sequence similarity with token-overlap similarity.

    Sequence similarity alone is poor for short chat phrases, so it is
    blended with Jaccard token overlap to better capture intent for
    free-form input like "hey there" vs "hey".
    """
    seq_score = SequenceMatcher(None, a, b).ratio()

    tokens_a, tokens_b = set(a.split()), set(b.split())
    if tokens_a and tokens_b:
        overlap = len(tokens_a & tokens_b) / len(tokens_a | tokens_b)
    else:
        overlap = 0.0

    return 0.5 * seq_score + 0.5 * overlap


class ChatEngine:
    """Loads intents and produces replies for user input.

    Example:
        >>> engine = ChatEngine()
        >>> reply = engine.get_response("hello")
        >>> isinstance(reply, str)
        True
    """

    def __init__(
        self,
        intents_path: Path | str = DEFAULT_INTENTS_PATH,
        match_threshold: float = MATCH_THRESHOLD,
        seed: Optional[int] = None,
    ) -> None:
        self.intents_path = Path(intents_path)
        self.match_threshold = match_threshold
        self.intents: List[Intent] = self._load_intents(self.intents_path)
        self._rng = random.Random(seed)
        self._history: List[tuple[str, str]] = []

    @staticmethod
    def _load_intents(path: Path) -> List[Intent]:
        if not path.exists():
            raise FileNotFoundError(f"Intents file not found: {path}")

        with path.open("r", encoding="utf-8") as fh:
            raw = json.load(fh)

        intents = [
            Intent(
                tag=item["tag"],
                patterns=item.get("patterns", []),
                responses=item.get("responses", []),
            )
            for item in raw.get("intents", [])
        ]

        if not any(i.tag == FALLBACK_TAG for i in intents):
            raise ValueError(
                f"Intents file must define a '{FALLBACK_TAG}' intent for unmatched input."
            )

        return intents

    def _find_fallback(self) -> Intent:
        return next(i for i in self.intents if i.tag == FALLBACK_TAG)

    def classify(self, text: str) -> Match:
        """Return the best-matching intent for the given input."""
        normalized = _normalize(text)
        best_intent: Optional[Intent] = None
        best_pattern: Optional[str] = None
        best_score = 0.0

        for intent in self.intents:
            if intent.tag == FALLBACK_TAG:
                continue
            for pattern in intent.patterns:
                score = _similarity(normalized, _normalize(pattern))
                if score > best_score:
                    best_score, best_intent, best_pattern = score, intent, pattern

        if best_intent is None or best_score < self.match_threshold:
            return Match(intent=self._find_fallback(), score=best_score, matched_pattern=None)

        return Match(intent=best_intent, score=best_score, matched_pattern=best_pattern)

    def get_response(self, text: str) -> str:
        """Classify input and return a randomly chosen response for the matched intent."""
        if not text or not text.strip():
            return "Please type something so I can respond."

        match = self.classify(text)
        response = self._rng.choice(match.intent.responses)
        self._history.append((text, response))
        return response

    @property
    def history(self) -> List[tuple[str, str]]:
        """Return the (user_input, bot_response) pairs from this session."""
        return list(self._history)
